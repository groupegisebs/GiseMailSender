@page
@model SecureMailGateway.Areas.Identity.Pages.Account.LockoutModel
@{
    ViewData["Title"] = "Compte verrouillé";
}

<div class="login-shell">
    <div class="login-card text-center">
        <div class="login-logo login-logo--warning mb-3">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h1 class="h4">Compte verrouillé</h1>
        <p class="text-muted">Trop de tentatives de connexion. Réessayez dans quelques minutes ou contactez un administrateur.</p>
        <a asp-page="./Login" class="btn btn-outline-primary mt-2">Retour à la connexion</a>
    </div>
</div>
