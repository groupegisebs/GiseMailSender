@page
@model SecureMailGateway.Areas.Identity.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Connexion";
}

<div class="login-shell">
    <div class="login-card">
        <div class="login-brand">
            <div class="login-logo">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1>SecureMail Gateway</h1>
            <p class="text-muted mb-0">Passerelle d'e-mails transactionnels sécurisée</p>
        </div>

        <form id="account" method="post" class="login-form">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" autofocus
                           placeholder="admin@securemail.local" />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password"
                           placeholder="••••••••••••" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label"></label>
            </div>

            <button type="submit" class="btn btn-primary w-100 login-submit">
                <i class="bi bi-box-arrow-in-right me-1"></i> Se connecter
            </button>
        </form>

        <p class="login-footer text-muted">
            <i class="bi bi-lock-fill me-1"></i> Accès réservé aux administrateurs autorisés.
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
