@using Microsoft.AspNetCore.Identity
@using SecureMailGateway.Models.Entities
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav align-items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <span class="nav-link text-muted small py-0">
            <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
        </span>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-sm btn-primary" asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right"></i> Connexion
        </a>
    </li>
}
</ul>
