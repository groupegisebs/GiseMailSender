@model TokenCreatedViewModel
@{ ViewData["Title"] = "Token créé"; }

<div class="alert alert-warning">
    <h4><i class="bi bi-exclamation-triangle"></i> Copiez ce token maintenant</h4>
    <p>Il ne sera plus affiché. Stockez-le dans un gestionnaire de secrets (pas dans Git).</p>
</div>

<div class="card p-4">
    <p><strong>Application :</strong> @Model.ClientName</p>
    <p><strong>Préfixe :</strong> <code>@Model.TokenPrefix</code></p>
    <div class="input-group mb-3">
        <input type="text" class="form-control font-monospace" id="tokenValue" value="@Model.PlainToken" readonly />
        <button class="btn btn-outline-primary" type="button" onclick="navigator.clipboard.writeText(document.getElementById('tokenValue').value)">Copier</button>
    </div>
    <p class="small text-muted mb-0">Utilisez <code>Authorization: Bearer &lt;token&gt;</code> ou l'en-tête <code>X-Api-Key</code>.</p>
</div>

<a asp-action="Index" class="btn btn-primary mt-3">Retour aux tokens</a>
