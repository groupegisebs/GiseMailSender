@model ClientApplicationViewModel
@{ ViewData["Title"] = "Modifier l'application"; }

<h1 class="mb-4">@ViewData["Title"]</h1>

<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ClientCode" />

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Code client</label>
            <input class="form-control" value="@Model.ClientCode" readonly />
        </div>
        <div class="col-md-3">
            <label asp-for="DailyQuota" class="form-label"></label>
            <input asp-for="DailyQuota" class="form-control" type="number" />
        </div>
        <div class="col-md-3">
            <label asp-for="MonthlyQuota" class="form-label"></label>
            <input asp-for="MonthlyQuota" class="form-control" type="number" />
        </div>
        <div class="col-md-6">
            <div class="form-check mt-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Application active</label>
            </div>
        </div>
        <div class="col-12">
            <partial name="_AllowedDomainsEditor" />
        </div>
        <div class="col-12">
            <label asp-for="AllowedIpAddresses" class="form-label">IPs autorisées</label>
            <input asp-for="AllowedIpAddresses" class="form-control" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Annuler</a>
    </div>
</form>

@section Scripts {
    <script src="~/js/client-application-form.js" asp-append-version="true"></script>
}
