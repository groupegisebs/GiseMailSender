@model IEnumerable<ClientApplication>
@{ ViewData["Title"] = "Applications clientes"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-app"></i> Applications clientes</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus"></i> Nouvelle application</a>
</div>

<table class="table table-hover bg-white rounded shadow-sm">
    <thead class="table-light">
        <tr>
            <th>Nom</th>
            <th>Code</th>
            <th>Quota/jour</th>
            <th>Quota/mois</th>
            <th>Domaines</th>
            <th>Statut</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td><code>@c.ClientCode</code></td>
                <td>@c.DailyQuota</td>
                <td>@c.MonthlyQuota</td>
                <td class="small text-muted">@(c.AllowedDomains ?? "—")</td>
                <td>
                    @if (c.IsActive)
                    { <span class="badge bg-success">Actif</span> }
                    else
                    { <span class="badge bg-secondary">Inactif</span> }
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@c.Id">Modifier</a>
                    <form class="d-inline" asp-action="Toggle" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@c.Id" />
                        <button class="btn btn-sm btn-outline-warning" type="submit">@(c.IsActive ? "Désactiver" : "Activer")</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
