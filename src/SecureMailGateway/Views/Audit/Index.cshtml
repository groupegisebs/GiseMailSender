@model IEnumerable<AuditLog>
@{ ViewData["Title"] = "Journal d'audit"; }

<h1 class="mb-4"><i class="bi bi-journal-text"></i> Journal d'audit</h1>

<form class="mb-3" method="get">
    <select name="action" class="form-select w-auto d-inline-block">
        <option value="">Toutes les actions</option>
        @foreach (AuditAction a in Enum.GetValues<AuditAction>())
        {
            <option value="@a" selected="@(ViewBag.Action as string == a.ToString())">@a</option>
        }
    </select>
    <button class="btn btn-primary" type="submit">Filtrer</button>
</form>

<table class="table table-sm table-hover bg-white rounded shadow-sm">
    <thead class="table-light">
        <tr><th>Date</th><th>Action</th><th>Entité</th><th>Application</th><th>IP</th><th>Détails</th></tr>
    </thead>
    <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td class="small">@l.CreatedAt.LocalDateTime.ToString("g")</td>
                <td><span class="badge bg-dark">@l.Action</span></td>
                <td>@(l.EntityType ?? "—") @(l.EntityId)</td>
                <td>@(l.ClientApplication?.Name ?? "—")</td>
                <td class="small">@(l.IpAddress ?? "—")</td>
                <td class="small text-muted text-truncate" style="max-width:250px">@(l.Details ?? "—")</td>
            </tr>
        }
    </tbody>
</table>
