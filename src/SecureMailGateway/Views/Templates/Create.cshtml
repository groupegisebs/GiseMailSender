@model EmailTemplateViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Éditer le template" : "Nouveau template";
    var variableNames = Model.Variables.Count > 0
        ? Model.Variables
        : ["FirstName", "CompanyName", "Title", "Message"];
}

<h1 class="mb-4">@ViewData["Title"]</h1>

<form asp-action="@(Model.Id.HasValue ? "Edit" : "Create")" method="post" id="templateForm">
    @Html.AntiForgeryToken()
    @if (Model.Id.HasValue) { <input type="hidden" asp-for="Id" /> }

    <div class="row g-3 mb-3">
        <div class="col-md-3">
            <label asp-for="TemplateCode" class="form-label">Code template</label>
            <input asp-for="TemplateCode" class="form-control" readonly="@(Model.Id.HasValue)" />
        </div>
        <div class="col-md-5">
            <label asp-for="Name" class="form-label">Nom</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-2">
            <label asp-for="Language" class="form-label">Langue</label>
            <input asp-for="Language" class="form-control" />
        </div>
        <div class="col-md-2">
            <div class="form-check mt-4">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">Actif</label>
            </div>
        </div>
        <div class="col-12">
            <label asp-for="SubjectTemplate" class="form-label">Sujet</label>
            <div class="input-group">
                <input asp-for="SubjectTemplate" class="form-control" id="subjectTemplate" placeholder="Ex. Bienvenue {{FirstName}} chez {{CompanyName}}" />
                <button type="button" class="btn btn-outline-secondary btn-insert-var" data-target="subjectTemplate" title="Insérer une variable dans le sujet">
                    <i class="bi bi-braces"></i> Variable
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                <label asp-for="HtmlBody" class="form-label mb-0">Corps du message</label>
                <div class="d-flex gap-2 align-items-center flex-wrap">
                    <select class="form-select form-select-sm" id="presetSelect" style="width:auto;">
                        <option value="">— Modèle de départ —</option>
                        <option value="welcome">Bienvenue</option>
                        <option value="notification">Notification</option>
                        <option value="alert">Alerte</option>
                        <option value="action">Bouton d'action</option>
                    </select>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btnApplyPreset">Appliquer</button>
                </div>
            </div>

            <div class="card p-3 mb-3 bg-white border">
                <h6 class="mb-2"><i class="bi bi-braces"></i> Variables du template</h6>
                <p class="form-text mb-2">Définissez les variables à insérer dans le sujet et le corps. Syntaxe : <code>{{NomVariable}}</code></p>
                <div class="row g-2 align-items-end mb-2">
                    <div class="col-sm-5">
                        <label class="form-label small mb-1" for="newVariableName">Nouvelle variable</label>
                        <input class="form-control form-control-sm" id="newVariableName" placeholder="Ex. OrderId, ResetLink" />
                    </div>
                    <div class="col-sm-3">
                        <button type="button" class="btn btn-sm btn-primary w-100" id="btnAddVariable">
                            <i class="bi bi-plus-lg"></i> Ajouter
                        </button>
                    </div>
                    <div class="col-sm-4">
                        <label class="form-label small mb-1" for="variableInsertSelect">Insérer dans le message</label>
                        <div class="input-group input-group-sm">
                            <select class="form-select" id="variableInsertSelect"></select>
                            <button type="button" class="btn btn-outline-primary" id="btnInsertVariable" title="Insérer">
                                <i class="bi bi-cursor-text"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div id="variableList">
                    @foreach (var v in variableNames)
                    {
                        <span class="badge bg-primary variable-badge me-1 mb-1" data-var="{{@v}}" data-name="@v">{{@v}}</span>
                    }
                </div>
            </div>

            <div class="template-editor-wrap">
                <textarea asp-for="HtmlBody"
                          class="form-control template-editor"
                          id="htmlBody"
                          rows="18"
                          data-preview-url="@Url.Action("Preview")"
                          data-variables="@string.Join(",", variableNames)"></textarea>
            </div>

            <label asp-for="TextBody" class="form-label mt-2">Corps texte (optionnel)</label>
            <textarea asp-for="TextBody" class="form-control" rows="4" id="textBody"></textarea>
        </div>

        <div class="col-lg-6">
            <label class="form-label">Aperçu en temps réel</label>
            <div class="preview-pane p-3" id="previewPane"></div>
            <div class="mt-3">
                <h6>Données de test <span class="text-muted fw-normal small">(pour l'aperçu)</span></h6>
                <div class="row g-2" id="sampleDataFields">
                    @foreach (var v in variableNames)
                    {
                        var sampleValue = v switch
                        {
                            "FirstName" => "Jean",
                            "CompanyName" => "Acme Corp",
                            "Title" => "Bienvenue",
                            "Message" => "Votre compte est prêt.",
                            _ => ""
                        };
                        <div class="col-6">
                            <input class="form-control form-control-sm sample-field" data-key="@v" placeholder="@v" value="@sampleValue" />
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        @if (Model.Id.HasValue)
        {
            <button type="button" class="btn btn-outline-info" id="btnPreview">Actualiser l'aperçu</button>
            <button type="button" class="btn btn-outline-success" data-bs-toggle="modal" data-bs-target="#testModal">Envoyer un test</button>
            <form class="d-inline" asp-action="Duplicate" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-outline-secondary" type="submit">Dupliquer</button>
            </form>
            <a asp-action="Versions" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Historique versions</a>
        }
        <a asp-action="Index" class="btn btn-link">Retour</a>
    </div>
</form>

@if (Model.Id.HasValue)
{
    <div class="modal fade" id="testModal" tabindex="-1">
        <div class="modal-dialog">
            <form asp-action="SendTest" method="post" class="modal-content">
                @Html.AntiForgeryToken()
                <input type="hidden" name="TemplateId" value="@Model.Id" />
                <input type="hidden" name="SubjectTemplate" id="testSubject" />
                <input type="hidden" name="HtmlBody" id="testHtml" />
                <input type="hidden" name="TextBody" id="testText" />
                <div class="modal-header"><h5 class="modal-title">Envoyer un e-mail test</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
                <div class="modal-body">
                    <label class="form-label">Destinataire</label>
                    <input name="TestEmail" class="form-control" type="email" required placeholder="vous@example.com" />
                    <div id="testSampleData"></div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Envoyer</button>
                </div>
            </form>
        </div>
    </div>
}

@section Styles {
    <link rel="stylesheet" href="~/lib/summernote/summernote-lite.min.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/lib/summernote/summernote-lite.min.js" asp-append-version="true"></script>
    <script src="~/lib/summernote/summernote-fr-FR.min.js" asp-append-version="true"></script>
    <script src="~/js/template-editor.js" asp-append-version="true"></script>
    <script>
        document.querySelectorAll('.btn-insert-var').forEach(btn => {
            btn.addEventListener('click', () => {
                const targetId = btn.dataset.target;
                const select = document.getElementById('variableInsertSelect');
                const name = select?.value;
                if (!name || !targetId) return;
                const input = document.getElementById(targetId);
                const token = '{{' + name + '}}';
                const start = input.selectionStart ?? input.value.length;
                const end = input.selectionEnd ?? input.value.length;
                input.value = input.value.slice(0, start) + token + input.value.slice(end);
                input.focus();
                input.selectionStart = input.selectionEnd = start + token.length;
                input.dispatchEvent(new Event('input'));
            });
        });
    </script>
}
