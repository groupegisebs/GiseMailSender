@model TemplatesIndexViewModel
@{ ViewData["Title"] = "Templates"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-file-earmark-richtext"></i> Templates</h1>
    <a class="btn btn-primary" asp-action="Create"><i class="bi bi-plus"></i> Nouveau template</a>
</div>

<form method="get" asp-action="Index" class="card p-3 mb-3">
    <div class="row g-2 align-items-end">
        <div class="col-md-5">
            <label class="form-label mb-1">Filtrer par application</label>
            <select name="clientCode" class="form-select">
                <option value="">Toutes les applications</option>
                @foreach (var option in Model.ApplicationFilters)
                {
                    if (string.Equals(Model.SelectedClientCode, option.ClientCode, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option.ClientCode" selected>@option.DisplayName</option>
                    }
                    else
                    {
                        <option value="@option.ClientCode">@option.DisplayName</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">Filtrer</button>
        </div>
    </div>
</form>

<table class="table table-hover bg-white rounded shadow-sm">
    <thead class="table-light">
        <tr>
            <th>Code</th>
            <th>Nom</th>
            <th>Langue</th>
            <th>Version</th>
            <th>Statut</th>
            <th>Modifié</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Templates.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Aucun template trouvé pour ce filtre.</td>
            </tr>
        }
        @foreach (var t in Model.Templates)
        {
            <tr>
                <td><code>@t.TemplateCode</code></td>
                <td>@t.Name</td>
                <td>@t.Language</td>
                <td>v@t.Version</td>
                <td>
                    @if (t.IsActive) { <span class="badge bg-success">Actif</span> }
                    else { <span class="badge bg-secondary">Inactif</span> }
                </td>
                <td class="small">@t.UpdatedAt.LocalDateTime.ToString("g")</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-primary" asp-action="Edit" asp-route-id="@t.Id">Éditer</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Versions" asp-route-id="@t.Id">Versions</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center">
    <small class="text-muted">
        @Model.TotalItems template(s) - page @Model.CurrentPage / @Model.TotalPages
    </small>
    <nav>
        <ul class="pagination mb-0">
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-clientCode="@Model.SelectedClientCode" asp-route-page="@(Model.CurrentPage - 1)">Precedent</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-clientCode="@Model.SelectedClientCode" asp-route-page="@p">@p</a>
                </li>
            }
            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                <a class="page-link" asp-action="Index" asp-route-clientCode="@Model.SelectedClientCode" asp-route-page="@(Model.CurrentPage + 1)">Suivant</a>
            </li>
        </ul>
    </nav>
</div>
